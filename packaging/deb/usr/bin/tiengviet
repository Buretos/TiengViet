#!/usr/bin/env python3
import functools
import http.server
import os
import urllib.parse
import urllib.request
import signal
import socket
import subprocess
import sys
import threading
import time


APP_DIR = "/usr/share/tiengviet/www"
APP_PORT = 8765


class QuietHandler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        if parsed.path == "/__gtts":
            self._handle_gtts(parsed)
            return
        super().do_GET()

    def _handle_gtts(self, parsed):
        params = urllib.parse.parse_qs(parsed.query)
        text = params.get("q", [""])[0].strip()
        lang = params.get("lang", ["vi"])[0]
        tl = "vi" if lang == "vi" else "ru"

        if not text:
            self.send_error(400, "empty text")
            return

        url = (
            "https://translate.google.com/translate_tts"
            "?ie=UTF-8&client=tw-ob&tl="
            + urllib.parse.quote(tl)
            + "&q="
            + urllib.parse.quote(text)
        )
        request = urllib.request.Request(
            url,
            headers={
                "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 "
                "(KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
                "Referer": "https://translate.google.com/",
                "Accept": "audio/mpeg,audio/*;q=0.9,*/*;q=0.5",
                "Accept-Language": "en-US,en;q=0.9,vi;q=0.8,ru;q=0.7",
            },
        )

        try:
            with urllib.request.urlopen(request, timeout=20) as response:
                body = response.read()
        except Exception as exc:
            self.send_error(502, f"gtts fetch failed: {exc}")
            return

        if not body:
            self.send_error(502, "empty gtts body")
            return

        self.send_response(200)
        self.send_header("Content-Type", "audio/mpeg")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, format, *args):
        return


def open_url(url):
    try:
        subprocess.Popen(["xdg-open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except OSError:
        print(url)


def is_existing_app_running():
    try:
        with urllib.request.urlopen(f"http://127.0.0.1:{APP_PORT}/index.html", timeout=1) as response:
            return response.status == 200
    except Exception:
        return False


def main():
    if not os.path.isdir(APP_DIR):
        print(f"Application files not found: {APP_DIR}", file=sys.stderr)
        return 1

    port = APP_PORT
    handler = functools.partial(QuietHandler, directory=APP_DIR)
    try:
        server = http.server.ThreadingHTTPServer(("127.0.0.1", port), handler)
    except OSError as exc:
        if is_existing_app_running():
            open_url(f"http://127.0.0.1:{APP_PORT}/")
            return 0
        print(f"Port {APP_PORT} is busy: {exc}", file=sys.stderr)
        return 1
    thread = threading.Thread(target=server.serve_forever, daemon=True)
    thread.start()

    url = f"http://127.0.0.1:{port}/"
    open_url(url)

    try:
        while True:
            time.sleep(3600)
    except KeyboardInterrupt:
        pass
    finally:
        server.shutdown()
    return 0


if __name__ == "__main__":
    signal.signal(signal.SIGTERM, lambda _signum, _frame: sys.exit(0))
    raise SystemExit(main())
